DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données (PostgreSQL + PostGIS par défaut)
POSTGRES_DB=discover_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password_discover_2026
POSTGRES_HOST=/var/run/postgresql
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Stockage R2 (Cloudflare)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=discover-senegal-media
AWS_S3_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
AWS_S3_REGION_NAME=auto
AWS_S3_USE_SSL=True
AWS_QUERYSTRING_AUTH=False
AWS_DEFAULT_ACL=public-read

# Services externes
MAADI_AI_URL=http://localhost:8001/maadi/recommend
MAADI_AI_TIMEOUT=300

# Firebase Admin (pour notifications push)
FIREBASE_CREDENTIALS_PATH=

# OAuth Google / Apple (P1)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_SERVICE_ID=
APPLE_OAUTH_KEY_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_PRIVATE_KEY=
